---
import "@fontsource/newsreader/300.css";
import "@fontsource/newsreader/400.css";
import "@fontsource/newsreader/400-italic.css";
import "@fontsource/newsreader/500.css";
import "@fontsource/hanken-grotesk/400.css";
import "@fontsource/hanken-grotesk/500.css";
import "@fontsource/hanken-grotesk/600.css";
import "@fontsource/hanken-grotesk/700.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  currentPage: string;
}

const { title, description, canonical, ogImage, ogType = "website", currentPage } = Astro.props;
const siteUrl = "https://sagarbarot.com";
const ogImageUrl = ogImage || `${siteUrl}/og-default.jpg`;
const pageTitle = currentPage === "home" ? title : `${title} | Sagar Barot`;
const addrParts = site.address.split(", ");
const streetAddr = addrParts.slice(0, -2).join(", ");
const locality = addrParts[addrParts.length - 2];
const lastPart = addrParts[addrParts.length - 1];
const regionMatch = lastPart.match(/^(.+?)\s*[–-]\s*(.+)$/);
const region = regionMatch ? regionMatch[1].trim().replace(/^Mumbai$/, "MH") : "MH";
const postalCode = regionMatch ? regionMatch[2].trim() : "400 057";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical || `${siteUrl}${Astro.url.pathname}`} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical || `${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Sagar Barot" />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#1B1916" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <meta name="theme-color" content="#1B1916" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Sagar Barot",
      jobTitle: "Founder & Managing Director",
      affiliation: {
        "@type": "Organization",
        name: "SNB Group of Companies",
      },
      description: "Second-generation real estate developer in Mumbai, specialising in luxury residences, redevelopment and commercial spaces.",
      url: siteUrl,
      sameAs: [site.instagram],
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Organization", "RealEstateAgent"],
      name: "SNB Group of Companies",
      legalName: "SNB Group of Companies",
      description: "Premium residential, commercial, mixed-use and redevelopment projects across Mumbai, Lonavala and Karjat.",
      url: siteUrl,
      email: site.email,
      telephone: site.phone,
      address: {
        "@type": "PostalAddress",
        streetAddress: streetAddr,
        addressLocality: locality,
        addressRegion: region,
        postalCode,
        addressCountry: "IN",
      },
      founder: {
        "@type": "Person",
        name: "Sagar Barot",
      },
      sameAs: [site.instagram],
    })} />
  </head>
  <body>
    <div class="site" style="background:var(--bg);min-height:100vh">
      <Header currentPage={currentPage} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      (function() {
        var els = document.querySelectorAll(".animate-in");
        if (!els.length) return;
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (!e.isIntersecting) return;
            e.target.classList.add("animate-in--visible");
            obs.unobserve(e.target);
          });
        }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });
        els.forEach(function(el) { obs.observe(el); });
      })();
    </script>
  </body>
</html>
