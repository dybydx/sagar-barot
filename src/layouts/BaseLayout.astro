---
import "@fontsource/newsreader/300.css";
import "@fontsource/newsreader/400.css";
import "@fontsource/newsreader/400-italic.css";
import "@fontsource/newsreader/500.css";
import "@fontsource/hanken-grotesk/400.css";
import "@fontsource/hanken-grotesk/500.css";
import "@fontsource/hanken-grotesk/600.css";
import "@fontsource/hanken-grotesk/700.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  currentPage: string;
}

const { title, description, canonical, ogImage, currentPage } = Astro.props;
const siteUrl = "https://sagarbarot.com";
const ogImageUrl = ogImage || `${siteUrl}/og-default.jpg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Sagar Barot</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical || `${siteUrl}${Astro.url.pathname}`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Sagar Barot`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical || `${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Sagar Barot" />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Sagar Barot`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Sagar Barot",
      jobTitle: "Founder & Managing Director",
      affiliation: {
        "@type": "Organization",
        name: "SNB Group of Companies",
      },
      description: "Second-generation real estate developer in Mumbai, specialising in luxury residences, redevelopment and commercial spaces.",
      url: siteUrl,
    })} />
  </head>
  <body>
    <div class="site" style="background:var(--bg);min-height:100vh">
      <Header currentPage={currentPage} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
