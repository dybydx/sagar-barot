---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { allPosts } from "../data/site";
const featured = allPosts[0];
const posts = allPosts.slice(1);
---
<BaseLayout
  title="Blog"
  description="Notes on building Mumbai — real estate, redevelopment, design, leadership and running a family business, in public."
  currentPage="blog"
>
  <section class="hero">
    <div class="container" style="padding:72px 32px 56px">
      <div class="eyebrow">Writing</div>
      <h1 class="hero-title">Notes on building Mumbai.</h1>
      <p class="hero-text">On real estate, redevelopment, design, leadership and the craft of running a family business — in public.</p>
    </div>
  </section>

  <section class="featured">
    <div class="container" style="padding:0 32px 40px">
      <PostCard post={featured} featured={true} />
    </div>
  </section>

  <section class="posts">
    <div class="container" style="padding:48px 32px 96px">
      <div class="posts-grid">
        {posts.map((p) => (
          <PostCard post={p} />
        ))}
      </div>
    </div>
  </section>

  <Newsletter />
</BaseLayout>

<style>
  .hero-title {
    font-family: "Newsreader", serif;
    font-weight: 400;
    font-size: clamp(40px, 5.2vw, 70px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0 0 24px;
    color: var(--ink);
    max-width: 16ch;
    text-wrap: balance;
  }

  .hero-text {
    font-size: 18px;
    line-height: 1.62;
    color: var(--ink2);
    max-width: 560px;
    margin: 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 32px;
  }
</style>
