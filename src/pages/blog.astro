---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const posts = allPosts.map((p) => {
  const d = p.data.date;
  return {
    cat: p.data.category,
    title: p.data.title,
    slug: p.id.replace(/\.(md|mdx)$/, ""),
    excerpt: p.data.excerpt,
    meta: `${months[d.getMonth()]} ${d.getFullYear()} \u00b7 ${p.data.readTime}`,
    ogImage: p.data.ogImage,
  };
});
const featured = posts.length > 0 ? posts[0] : null;
const rest = featured ? posts.slice(1) : [];
---
<BaseLayout
  title="Blog — Sagar Barot on Building Mumbai"
  description="Notes on real estate, redevelopment, design, leadership and running a family business in Mumbai — by Sagar Barot."
  currentPage="blog"
>
  <section class="hero">
    <div class="container" style="padding:72px 32px 56px">
      <div class="eyebrow">Writing</div>
      <h1 class="hero-title">Notes on building Mumbai.</h1>
      <p class="hero-text">On real estate, redevelopment, design, leadership and the craft of running a family business — in public.</p>
    </div>
  </section>

  {featured && (
    <section class="featured">
      <div class="container" style="padding:0 32px 40px">
        <PostCard post={featured} featured={true} />
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <section class="posts">
      <div class="container" style="padding:48px 32px 96px">
        <div class="posts-grid">
          {rest.map((p) => (
            <PostCard post={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  <Newsletter />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://sagarbarot.com/" },
    { "@type": "ListItem", position: 2, name: "Blog", item: "https://sagarbarot.com/blog/" },
  ],
})} />

<style>
  .hero-title {
    font-family: "Newsreader", serif;
    font-weight: 400;
    font-size: clamp(40px, 5.2vw, 70px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0 0 24px;
    color: var(--ink);
    max-width: 16ch;
    text-wrap: balance;
  }

  .hero-text {
    font-size: 18px;
    line-height: 1.62;
    color: var(--ink2);
    max-width: 560px;
    margin: 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 32px;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .featured .container {
      padding: 0 20px 32px;
    }

    .posts .container {
      padding: 32px 20px 72px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
