---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const slug = post.id.replace(/\.(md|mdx)$/, "");
const { Content } = await render(post);
const siteUrl = "https://sagarbarot.com";
const articleUrl = `${siteUrl}/blog/${slug}/`;
const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const d = post.data.date;
const meta = `${months[d.getMonth()]} ${d.getFullYear()} \u00b7 ${post.data.readTime}`;
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  canonical={articleUrl}
  currentPage="blog"
>
  <article class="blog-article">
    <div class="container">
      <header class="blog-header">
        <a href="/blog/" class="blog-back">&larr; Back to all writing</a>
        <div class="blog-cat">{post.data.category}</div>
        <h1 class="blog-title">{post.data.title}</h1>
        <div class="blog-meta">{meta}</div>
      </header>

      <div class="blog-content">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.excerpt,
  author: {
    "@type": "Person",
    name: "Sagar Barot",
  },
  publisher: {
    "@type": "Organization",
    name: "SNB Group of Companies",
  },
  datePublished: post.data.date.toISOString().split("T")[0],
  url: articleUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleUrl,
  },
})} />

<style>
  .blog-article {
    padding: 64px 0 96px;
  }

  .blog-article .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .blog-back {
    display: inline-block;
    font: 500 13px "Hanken Grotesk", sans-serif;
    color: var(--ink3);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .blog-back:hover {
    color: var(--accent-deep);
  }

  .blog-header {
    margin-bottom: 48px;
  }

  .blog-cat {
    font: 700 11px "Space Mono", monospace;
    letter-spacing: 0.18em;
    color: var(--accent-deep);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .blog-title {
    font-family: "Newsreader", serif;
    font-weight: 400;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 20px;
    text-wrap: balance;
  }

  .blog-meta {
    font: 500 13px "Hanken Grotesk", sans-serif;
    color: var(--ink3);
  }

  .blog-content {
    font-size: 17px;
    line-height: 1.75;
    color: var(--ink);
  }

  .blog-content :global(h2) {
    font-family: "Newsreader", serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.3;
    color: var(--ink);
    margin: 40px 0 16px;
  }

  .blog-content :global(p) {
    margin: 0 0 24px;
  }

  @media (max-width: 768px) {
    .blog-article {
      padding: 40px 0 72px;
    }

    .blog-article .container {
      padding: 0 20px;
    }

    .blog-content {
      font-size: 16px;
    }
  }
</style>
