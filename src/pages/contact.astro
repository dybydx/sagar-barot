---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
const addrParts = site.address.split(", ");
---
<BaseLayout
  title="Contact"
  description="Get in touch with Sagar Barot — redevelopment enquiries, partnerships, press and speaking. Based in Vile Parle East, Mumbai."
  currentPage="contact"
>
  <section class="hero">
    <div class="container" style="padding:72px 32px 56px">
      <div class="eyebrow">Contact</div>
      <h1 class="hero-title">Let's start a conversation.</h1>
      <p class="hero-text">Redevelopment enquiries, partnerships, press and speaking — reach out and I'll get back to you personally.</p>
    </div>
  </section>

  <section class="contact-main">
    <div class="container" style="padding:24px 32px 96px">
      <div class="contact-grid">
        <div class="contact-form-wrapper">
          <div id="contact-form-root">
            <div id="contact-form-show">
              <form id="contact-form" class="contact-form">
                <div class="form-row">
                  <label class="form-field">
                    <span class="form-label">Name</span>
                    <input required placeholder="Your name" name="name" />
                  </label>
                  <label class="form-field">
                    <span class="form-label">Phone</span>
                    <input placeholder="+91 " name="phone" />
                  </label>
                </div>
                <label class="form-field">
                  <span class="form-label">Email</span>
                  <input required type="email" placeholder="you@email.com" name="email" />
                </label>
                <label class="form-field">
                  <span class="form-label">What's on your mind?</span>
                  <textarea required rows="5" placeholder="Tell me a little about your enquiry…" name="message"></textarea>
                </label>
                <button type="submit" class="form-btn">Send message</button>
              </form>
            </div>
            <div id="contact-form-thanks" style="display:none">
              <div class="thanks-title">Thank you.</div>
              <p class="thanks-text">Your message is on its way. I'll be in touch shortly — usually within a couple of working days.</p>
            </div>
          </div>
        </div>

        <div class="contact-info">
          <div>
            <div class="info-label">Corporate Office</div>
            <p class="info-text">
              {addrParts.slice(0, 3).join(", ")}<br />
              {addrParts.slice(3).join(", ")}
            </p>
          </div>
          <div class="info-block">
            <div class="info-label">Email</div>
            <a href={`mailto:${site.email}`} class="info-link">{site.email}</a>
          </div>
          <div class="info-block">
            <div class="info-label">Phone</div>
            <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="info-link">{site.phone}</a>
          </div>
          <div class="info-block">
            <div class="info-label">Social</div>
            <a href={site.instagram} target="_blank" rel="noopener" class="info-link">Instagram → @snb_group_of_companies</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("contact-form");
    if (!form) return;
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const root = document.getElementById("contact-form-root");
      if (!root) return;
      root.querySelector("#contact-form-show").style.display = "none";
      root.querySelector("#contact-form-thanks").style.display = "block";
    });
  });
</script>

<style>
  .hero-title {
    font-family: "Newsreader", serif;
    font-weight: 400;
    font-size: clamp(40px, 5.2vw, 70px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0 0 24px;
    color: var(--ink);
    max-width: 15ch;
    text-wrap: balance;
  }

  .hero-text {
    font-size: 18px;
    line-height: 1.62;
    color: var(--ink2);
    max-width: 560px;
    margin: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 64px;
    align-items: start;
  }

  .contact-info {
    border-top: 1px solid var(--rule);
    padding-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .info-label {
    font: 700 10px "Space Mono", monospace;
    letter-spacing: 0.16em;
    color: var(--accent-deep);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .info-text {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0;
  }

  .info-block {
    border-top: 1px solid var(--rule);
    padding-top: 24px;
  }

  .info-link {
    font-size: 16px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    transition: border-color 0.2s;
  }

  .info-link:hover {
    border-color: var(--ink);
  }

  .contact-form-wrapper {
    border-top: 1px solid var(--rule);
    padding-top: 40px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .form-label {
    font: 700 10px "Space Mono", monospace;
    letter-spacing: 0.14em;
    color: var(--ink3);
    text-transform: uppercase;
  }

  .form-field input,
  .form-field textarea {
    padding: 13px 15px;
    border: 1px solid var(--rule);
    border-radius: 2px;
    background: var(--panel);
    font: 400 15px "Hanken Grotesk";
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--accent-deep);
  }

  .form-field textarea {
    resize: vertical;
  }

  .form-btn {
    background: var(--ink);
    color: var(--bg);
    border: none;
    cursor: pointer;
    padding: 15px 30px;
    font: 600 12px "Hanken Grotesk";
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s;
  }

  .form-btn:hover {
    background: var(--accent-deep);
  }

  .thanks-title {
    font-family: "Newsreader", serif;
    font-size: 30px;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .thanks-text {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink2);
    margin: 0;
    max-width: 420px;
  }
</style>
