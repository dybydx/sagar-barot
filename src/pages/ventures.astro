---
import BaseLayout from "../layouts/BaseLayout.astro";
import VerticalCard from "../components/VerticalCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { verticals, projects } from "../data/site";
---
<BaseLayout
  title="Ventures"
  description="SNB Group of Companies — premium residential, commercial, mixed-use and redevelopment projects across Mumbai, Lonavala and Karjat."
  currentPage="ventures"
>
  <section class="hero">
    <div class="container" style="padding:72px 32px 48px">
      <div class="eyebrow">Ventures</div>
      <h1 class="hero-title">SNB Group of Companies</h1>
      <p class="hero-text">Premium residential and commercial real estate in Mumbai — luxury homes, villas, office spaces and large-scale redevelopment, built across Vile Parle, Andheri, Goregaon and beyond.</p>
    </div>
  </section>

  <section class="verticals">
    <div class="container verticals-grid" style="padding:0 32px">
      {verticals.map((v) => (
        <VerticalCard vertical={v} />
      ))}
    </div>
  </section>

  <section class="projects">
    <div class="container" style="padding:96px 32px">
      <div class="projects-header">
        <h2 class="projects-title">Selected projects</h2>
        <div class="projects-regions">Mumbai · Lonavala · Karjat</div>
      </div>
      <div class="projects-grid">
        {projects.map((p) => (
          <ProjectCard project={p} />
        ))}
      </div>
    </div>
  </section>

  <section class="mission">
    <div class="mission-inner">
      <div class="eyebrow" style="text-align:center">Our Mission</div>
      <p class="mission-text">To create forward-thinking real estate that responds to the changing needs of modern urban life — with innovation, integrity and long-term value.</p>
      <a href="https://snbgroup.in/" target="_blank" rel="noopener" class="mission-btn">Visit snbgroup.in →</a>
    </div>
  </section>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://sagarbarot.com/" },
    { "@type": "ListItem", position: 2, name: "Ventures", item: "https://sagarbarot.com/ventures/" },
  ],
})} />

<style>
  .hero-title {
    font-family: "Newsreader", serif;
    font-weight: 400;
    font-size: clamp(40px, 5.2vw, 70px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0 0 24px;
    color: var(--ink);
    max-width: 14ch;
    text-wrap: balance;
  }

  .hero-text {
    font-size: 18px;
    line-height: 1.62;
    color: var(--ink2);
    max-width: 620px;
    margin: 0;
  }

  .verticals {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .verticals-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .projects-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 44px;
    flex-wrap: wrap;
  }

  .projects-title {
    font-family: "Newsreader", serif;
    font-weight: 400;
    font-size: clamp(28px, 3.2vw, 42px);
    line-height: 1.05;
    margin: 0;
    color: var(--ink);
  }

  .projects-regions {
    font: 600 11px "Space Mono", monospace;
    letter-spacing: 0.14em;
    color: var(--ink3);
    text-transform: uppercase;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .mission {
    background: var(--panel);
    border-top: 1px solid var(--rule);
  }

  .mission-inner {
    max-width: 920px;
    margin: 0 auto;
    padding: 96px 32px;
    text-align: center;
  }

  .mission-text {
    font-family: "Newsreader", serif;
    font-weight: 300;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.32;
    color: var(--ink);
    margin: 0 0 36px;
    text-wrap: balance;
  }

  .mission-btn {
    display: inline-block;
    background: var(--ink);
    color: var(--bg);
    text-decoration: none;
    padding: 15px 28px;
    font: 600 12px "Hanken Grotesk";
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s;
  }

  .mission-btn:hover {
    background: var(--accent-deep);
  }

  @media (max-width: 768px) {
    .verticals-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .projects-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .mission-inner {
      padding: 72px 20px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .verticals-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
