---
import { navItems } from "../data/site";

export interface Props {
  currentPage: string;
}

const { currentPage } = Astro.props;
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-name">Sagar Barot</span>
      <span class="logo-sub">SNB GROUP</span>
    </a>

    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <nav class="nav" id="nav">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`nav-link${currentPage === item.key ? " nav-link--active" : ""}`}
        >
          {item.label}
          {currentPage === item.key && <span class="nav-underline"></span>}
        </a>
      ))}
      <a href="/contact/" class="btn-header nav-btn-mobile">Get in touch</a>
    </nav>

    <a href="/contact/" class="btn-header btn-header-desktop">Get in touch</a>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const hamburger = document.getElementById("hamburger");
    const nav = document.getElementById("nav");
    if (!hamburger || !nav) return;
    hamburger.addEventListener("click", () => {
      nav.classList.toggle("nav--open");
      hamburger.classList.toggle("hamburger--active");
      document.body.classList.toggle("nav-open");
    });
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--rule);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .logo {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1px;
    text-decoration: none;
  }

  .logo-name {
    font-family: "Newsreader", serif;
    font-size: 21px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--ink);
    line-height: 1;
  }

  .logo-sub {
    font: 700 9px "Space Mono", monospace;
    letter-spacing: 0.32em;
    color: var(--accent-deep);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .nav-link {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 0;
    font: 600 12px "Hanken Grotesk";
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink2);
    transition: color 0.2s;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--accent);
  }

  .btn-header {
    background: var(--ink);
    color: var(--bg);
    border: none;
    cursor: pointer;
    padding: 11px 20px;
    font: 600 11px "Hanken Grotesk";
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s;
    text-decoration: none;
  }

  .btn-header:hover {
    background: var(--accent-deep);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 60;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 1px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .hamburger--active .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger--active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger--active .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .btn-header-desktop {
    flex-shrink: 0;
  }

  .nav-btn-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .header-inner {
      padding: 0 20px;
      height: 64px;
    }

    .hamburger {
      display: flex;
    }

    .btn-header-desktop {
      display: none;
    }

    .nav {
      position: fixed;
      top: 0;
      right: 0;
      width: 280px;
      height: 100vh;
      background: var(--panel);
      flex-direction: column;
      padding: 96px 32px 32px;
      gap: 8px;
      transform: translateX(100%);
      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: -8px 0 30px rgba(0, 0, 0, 0.08);
      z-index: 55;
      align-items: stretch;
    }

    .nav--open {
      transform: translateX(0);
    }

    .nav-link {
      font-size: 14px;
      padding: 14px 0;
      border-bottom: 1px solid var(--rule);
    }

    .nav-btn-mobile {
      display: block;
      margin-top: 12px;
      text-align: center;
    }
  }
</style>
