---
export interface Props {
  quote: string;
  attribution: string;
}
const { quote, attribution } = Astro.props;
---

<div class="pullquote">
  <p class="pullquote-text">{quote}</p>
  <div class="pullquote-attribution">{attribution}</div>
</div>

<style>
  .pullquote {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--panel);
  }

  .pullquote-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 96px 32px;
    text-align: center;
  }

  .pullquote-text {
    font-family: "Newsreader", serif;
    font-weight: 300;
    font-size: clamp(26px, 3.4vw, 40px);
    line-height: 1.3;
    color: var(--ink);
    margin: 0 0 24px;
    text-wrap: balance;
  }

  .pullquote-attribution {
    font-family: "Newsreader", serif;
    font-style: italic;
    font-size: 19px;
    color: var(--accent-deep);
  }
</style>
