---
export interface Props {
  value: { t: string; d: string };
}
const { value: v } = Astro.props;
---

<div class="value-card animate-in">
  <h3 class="value-title">{v.t}</h3>
  <p class="value-desc">{v.d}</p>
</div>

<style>
  .value-card {
    background: var(--bg);
    padding: 34px 26px;
    min-height: 220px;
    transition: transform 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
  }

  .value-card:hover {
    transform: translateY(-3px);
  }

  .value-title {
    font-family: "Newsreader", serif;
    font-weight: 400;
    font-size: 22px;
    color: var(--ink);
    margin: 0 0 12px;
  }

  .value-desc {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink2);
    margin: 0;
  }
</style>
